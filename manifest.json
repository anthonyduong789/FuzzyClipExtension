{
  "name": "Fuzzy Note Copy",
  "version": "0.0.0.1",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle FuzzyClip"
  },
  "description": "browser note that allows your to easily copy and past things ans also search with a quick keymaps",
  "permissions": ["activeTab", "scripting", "storage", "clipboardWrite"],
  "web_accessible_resources": [
    {
      "resources": [
        "fuzzy.html",
        "content.js",
        "fuzzy.css",
        "styles/styles.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_end"
    }
  ]
}
